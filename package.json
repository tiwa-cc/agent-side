{
  "name": "agent-side",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "bin": {
    "agent-side": "./dist/cli/main.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/index.js",
    "./renderer/bootstrap": "./dist/renderer/bootstrap/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/index.html",
    "templates",
    "themes",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/main.ts",
    "validate": "tsx src/cli/main.ts validate docs/index.yml",
    "render": "tsx src/cli/main.ts render docs/index.yml --out dist",
    "preview": "vite --host 127.0.0.1",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w .",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "consola": "^3.2.3",
    "fs-extra": "^11.2.0",
    "html-escaper": "^3.0.3",
    "pathe": "^1.1.2",
    "sirv": "^2.0.4",
    "smol-toml": "^1.3.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
