{
  "name": "agent-side",
  "version": "0.1.0",
  "description": "AI-safe document rendering layer where agents write structured meaning and renderers generate human-readable output.",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "packageManager": "pnpm@10.10.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiwa-cc/agent-side.git"
  },
  "bugs": {
    "url": "https://github.com/tiwa-cc/agent-side/issues"
  },
  "homepage": "https://github.com/tiwa-cc/agent-side#readme",
  "keywords": [
    "ai",
    "ai-agent",
    "document-generation",
    "yaml",
    "renderer",
    "typescript",
    "bootstrap",
    "mermaid",
    "static-site-generator",
    "docir"
  ],
  "bin": {
    "agent-side": "./lib/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./core": {
      "types": "./lib/core/index.d.ts",
      "import": "./lib/core/index.js"
    },
    "./renderer/bootstrap": {
      "types": "./lib/renderer/bootstrap/index.d.ts",
      "import": "./lib/renderer/bootstrap/index.js"
    },
    "./renderer/plain": {
      "types": "./lib/renderer/plain/index.d.ts",
      "import": "./lib/renderer/plain/index.js"
    },
    "./renderer/markdown": {
      "types": "./lib/renderer/markdown/index.d.ts",
      "import": "./lib/renderer/markdown/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "templates",
    "themes",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('lib', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/main.ts",
    "validate": "tsx src/cli/main.ts validate docs/index.yml",
    "render": "tsx src/cli/main.ts render docs/index.yml --out dist",
    "preview": "vite --host 127.0.0.1",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w .",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "consola": "^3.2.3",
    "fs-extra": "^11.2.0",
    "html-escaper": "^3.0.3",
    "pathe": "^1.1.2",
    "sirv": "^2.0.4",
    "smol-toml": "^1.3.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
