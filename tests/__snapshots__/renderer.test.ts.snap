// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`bootstrap renderer > renders stable semantic HTML for representative blocks 1`] = `
"<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Renderer Snapshot</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f8f9fa; }
    .doc-shell { max-width: 960px; margin: 0 auto; padding: 48px 20px 72px; background: #fff; min-height: 100vh; }
    .doc-section { margin-top: 2rem; }
    .doc-wide { max-width: 1120px; }
    .doc-full { max-width: none; }
    h1, h2, h3 { letter-spacing: 0; }
    pre { padding: 1rem; background: #212529; color: #f8f9fa; border-radius: .375rem; overflow-x: auto; }
    .mermaid-source { background: #fff; color: #212529; border: 1px solid #dee2e6; }
    .mermaid-output svg { max-width: 100%; height: auto; }
  </style>
</head>
<body>
  <main class="doc-shell">
    <header class="mb-5">
      <h1>Renderer Snapshot</h1>
      <p class="lead">Snapshot target</p>
    </header>
    <div class="alert alert-info" role="note"><h2 class="h5">Notice</h2><p>Read this.</p></div>
<section class="doc-section"><h2>Section</h2><h3>Flow</h3><div class="mermaid-block"><pre class="mermaid-source">flowchart TD
  A --&gt; B</pre><div class="mermaid-output" aria-hidden="true"></div></div>
<article class="border-start border-success border-4 ps-3 my-4"><h3 class="h5">Decision</h3><p><strong>Decision:</strong> Use DocIR.</p><p><strong>Rationale:</strong> It is structured.</p></article>
<section><h3>Table</h3><div class="table-responsive"><table class="table table-striped align-middle"><thead><tr><th scope="col">Name</th><th scope="col">Value</th></tr></thead><tbody><tr><td>Renderer</td><td>Bootstrap</td></tr></tbody></table></div></section>
<section><h3>Cards</h3><div class="row g-3"><div class="col-md-4"><article class="card h-100"><div class="card-body"><h4 class="h5">Card</h4><p>Grouped item.</p></div></article></div></div></section>
<article class="border-start border-warning border-4 ps-3 my-4"><h3 class="h5">Risk</h3><p><strong>Risk:</strong> Presentation leakage.</p><p><strong>Mitigation:</strong> Validate keys.</p></article></section>
  </main>
  <script type="module">
import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs";
mermaid.initialize({ startOnLoad: false });
for (const [index, block] of document.querySelectorAll(".mermaid-block").entries()) {
  const source = block.querySelector(".mermaid-source");
  const output = block.querySelector(".mermaid-output");
  try {
    const { svg } = await mermaid.render(\`docir-mermaid-\${index}\`, source.textContent || "");
    output.innerHTML = svg;
    output.removeAttribute("aria-hidden");
    source.hidden = true;
  } catch (error) {
    const message = document.createElement("p");
    message.className = "alert alert-warning mt-2";
    message.textContent = "Mermaid rendering failed. The diagram source is shown above.";
    block.append(message);
  }
}
</script>
</body>
</html>
"
`;
